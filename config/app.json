{
  "qdrant": {
    "url": "http://127.0.0.1:3333", // Qdrant 服务地址
    "collection": "faq", // 集合名（你的 FAQ 集合）
    "pending_collection": "pending_kb", // 待审核集合名（LLM结果待人工通过）
    "docs_collection": "kb_docs_v1", // 文档分片集合名（导入文件切片后写入）
    "timeout_seconds": 5 // 请求超时（秒）
  },
  "embedding": {
    "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1", // 阿里云百炼(北京)兼容接口，国际站可改为 https://dashscope-intl.aliyuncs.com/compatible-mode/v1
    "model": "text-embedding-v4", // 千问 Embedding 模型
    "api_key_env": "DASHSCOPE_API_KEY", // 环境变量名（程序将读取该变量中的真实key）
    "timeout_seconds": 15 // 请求超时（秒）
  },
  "api": {
    "similarity_threshold": 0.8, // 相似度阈值（0~1），低于该值返回未配置
    "min_embedding_chars": 2, // 归一化后长度小于该值时，不走embedding，直接返回未配置
    "not_configured_answer": "暂时没有学会!", // 未命中时兜底回复
    "auto_retrieve_knowledge": true, // 是否自动检索知识库（false时跳过步骤3-6，直接返回兜底）
    "enable_qa_model": true, // 是否调用问答模型
    "auto_cache_qa_answer": true // 是否自动把问答模型结果写入知识库
  },
  "qa": {
    "qa_base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1", // 问答模型接口地址
    "qa_model": "qwen3.6-flash", // 问答模型名称
    "qa_api_key_env": "DASHSCOPE_API_KEY", // 问答模型 API Key 环境变量名
    "qa_timeout_seconds": 30, // 问答模型请求超时（秒）
    "qa_prompt_template": "### 指令与角色设定 (Instruction) ###\n你现在是的专业资深售后客服。\n请严格遵循以下规则：\n1. **语气准则**：温和、专业、客观。使用“您”，严禁使用过度讨好的语气。\n2. **权限边界**：严禁主动提出“补偿”、“优惠”、“折扣”或“赠品”。\n3. **拒绝艺术**：若用户诉求违反【知识库】规定（如超时），请委婉但坚定地拒绝，并说明原因。\n4. **专业建议**：拒绝后，必须基于知识库提供专业的尺码建议或解决办法，引导用户正确选购。\n5. **数据校对**：引用日期必须与【业务背景】一致，严禁虚构。\n\n### 参考知识库 (Knowledge Base) ###\n1. 退换货策略：签收后7天内支持无理由退换，需保持吊牌完整。\n2. 物流时效：西马地区3-5天，东马地区5-7天。\n3. 客服在线时间：9:00-18:00\n\n### 用户当前提问 (User Query) ###\n\"{content}\"\n---\n\n### 你的回复 (Response) 使用中文回答 (100个字以内) ###" // LLM自定义模版，必须包含 {content}
  },
  "web": {
    "enabled": true, // 是否启用Web应答界面（false时关闭 /web）
    "chat_title": "智能客服", // 应答页面标题
    "welcome_template": "您好,{username}，欢迎来到客服中心😊\n我是您的在线助手，将协助您完成咨询与处理。\n您可以咨询产品、订单、售后等相关问题。\n请尽量描述清楚您的情况，我会更高效帮您解决。\n祝您体验愉快，期待为您服务！", // 首次进入欢迎语模版，支持 {username}，留空则不推送
    "quick_phrases": ["怎么退款", "多久到账", "客服在线时间"] // 应答页面快捷语（按钮）
  },
  "admin": {
    "password": "admin", // 后台固定登录密码（建议改成你自己的）
    "session_ttl_seconds": 28800 // 后台登录态有效期（秒）
  }
}
